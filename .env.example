# =============================================================
# NewsVerified AI — Environment Variables
# Copy this file to .env and fill in your API keys.
# =============================================================

# -------------------------------------------------------
# REQUIRED: Groq API (LLM analysis — Tamil + English)
# Get a free key at https://console.groq.com/
# -------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override the default Groq model selection.
# If not set, the app auto-selects the best available model:
#   1. llama-3.3-70b-versatile  (best Tamil support)
#   2. mixtral-8x7b-32768       (good multilingual)
#   3. llama-3.1-8b-instant     (fastest / free tier)
# GROQ_MODEL=llama-3.3-70b-versatile

# -------------------------------------------------------
# OPTIONAL: NewsAPI (English news — adds English sources)
# Get a free key at https://newsapi.org/
# Without this, only Google News RSS is used for English.
# -------------------------------------------------------
NEWS_API_KEY=your_newsapi_key_here

# -------------------------------------------------------
# OPTIONAL: GNews API (supports Tamil: lang=ta, country=IN)
# Get a free key at https://gnews.io/ (100 req/day free)
# -------------------------------------------------------
GNEWS_API_KEY=your_gnews_api_key_here

# -------------------------------------------------------
# OPTIONAL: NewsData.io (supports language=tamil)
# Get a free key at https://newsdata.io/ (200 req/day free)
# -------------------------------------------------------
NEWSDATA_API_KEY=your_newsdata_api_key_here

# -------------------------------------------------------
# DATA PATHS (defaults shown — usually no need to change)
# -------------------------------------------------------
HISTORY_PATH=history.json
LATEST_NEWS_PATH=latest_news.json

# -------------------------------------------------------
# PERFORMANCE TUNING
# -------------------------------------------------------
# Timeout in seconds for fetching external URLs and news
NEWS_TIMEOUT_SECONDS=12
URL_FETCH_TIMEOUT_SECONDS=12

# Video: number of frames to sample
VIDEO_MAX_FRAMES=16

# Video: how many seconds between sampled frames
VIDEO_SAMPLE_INTERVAL_SECONDS=1
